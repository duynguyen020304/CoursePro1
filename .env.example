# CoursePro1 Environment Configuration
# REQUIRED: API_BASE_URL must be explicitly set - no auto-detection
# Dev environment example: http://localhost:8001/api/
# Production example: https://yourdomain.com/api/

API_BASE_URL=http://localhost:8001/api/
JWT_SECRET_KEY=0196ce3e-ba28-7b47-8472-beded9ae0b5d

# Database Configuration (MySQL)
# For Docker setup: DB_HOST=mysql (container name) or localhost if running locally
DB_HOST=localhost
DB_NAME=ecourse
DB_USER=root
DB_PASSWORD=
DB_PORT=3306

# Docker MySQL credentials (if using docker-compose)
# DB_HOST=mysql
# DB_USER=coursepro_user
# DB_PASSWORD=coursepro_pass

# Python AI Service Configuration
# For Docker: DB_HOST=mysql, for local: DB_HOST=localhost
PYTHON_AI_PORT=5000