# Example .htaccess for api directory
RewriteEngine On

# If the request is not for an existing file
RewriteCond %{REQUEST_FILENAME} !-f
# If the request is not for an existing directory
RewriteCond %{REQUEST_FILENAME} !-d

# Rewrite the request to course_api.php, appending the path
# e.g., /api/sort/price -> /api/course_api.php/sort/price
RewriteRule ^(.*)$ course_api.php/$1 [L,QSA]